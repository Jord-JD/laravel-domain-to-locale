{
  "name": "jord-jd/laravel-domain-to-locale",
  "description": "Change your Laravel app's locale based on the domain name",
  "type": "library",
  "license": "LGPL-3.0-only",
  "authors": [
    {
      "name": "Jordan Hall",
      "email": "jordan@hall05.co.uk"
    }
  ],
  "require": {
    "php": ">=7.1",
    "laravel/framework": "^5.6||^6.0||^7.0||^8.0||^9.0||^10.0||^11.0||^12.0||^13.0"
  },
  "autoload": {
    "psr-4": {
      "JordJD\\LaravelDomainToLocale\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "JordJD\\LaravelDomainToLocale\\Tests\\": "tests/"
    }
  },
  "require-dev": {
    "phpunit/phpunit": "^7.5||^9.6||^12.0"
  },
  "extra": {
    "laravel": {
      "providers": [
        "JordJD\\LaravelDomainToLocale\\ServiceProvider"
      ]
    },
    "branch-alias": {
      "dev-master": "3.0-dev"
    }
  },
  "replace": {
    "divineomega/laravel-domain-to-locale": "self.version"
  }
}
